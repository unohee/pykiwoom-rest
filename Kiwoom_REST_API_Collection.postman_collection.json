    {
      "name": "Trading",
      "description": "주문 관련 API",
      "item": [
        {
          "name": "Buy Order (매수주문)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "appkey",
                "value": "{{app_key}}"
              },
              {
                "key": "appsecret",
                "value": "{{app_secret}}"
              },
              {
                "key": "tr_id",
                "value": "TTTC0802U"
              },
              {
                "key": "hashkey",
                "value": "{{hashkey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"CANO\": \"{{account_no}}\",\n  \"ACNT_PRDT_CD\": \"01\",\n  \"PDNO\": \"005930\",\n  \"ORD_DVSN\": \"01\",\n  \"ORD_QTY\": \"1\",\n  \"ORD_UNPR\": \"70000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/uapi/domestic-stock/v1/trading/order-cash",
              "host": ["{{base_url}}"],
              "path": ["uapi", "domestic-stock", "v1", "trading", "order-cash"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Hashkey 생성을 위한 사전 요청",
                  "const hashKeyRequest = {",
                  "  url: pm.collectionVariables.get('base_url') + '/uapi/hashkey',",
                  "  method: 'POST',",
                  "  header: {",
                  "    'Authorization': 'Bearer ' + pm.collectionVariables.get('access_token'),",
                  "    'appkey': pm.collectionVariables.get('app_key'),",
                  "    'appsecret': pm.collectionVariables.get('app_secret'),",
                  "    'Content-Type': 'application/json'",
                  "  },",
                  "  body: {",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({",
                  "      'CANO': pm.collectionVariables.get('account_no'),",
                  "      'ACNT_PRDT_CD': '01',",
                  "      'PDNO': '005930',",
                  "      'ORD_DVSN': '01',",
                  "      'ORD_QTY': '1',",
                  "      'ORD_UNPR': '70000'",
                  "    })",
                  "  }",
                  "};",
                  "",
                  "pm.sendRequest(hashKeyRequest, (error, response) => {",
                  "  if (error) {",
                  "    console.log('Hashkey request error:', error);",
                  "  } else {",
                  "    const hashkey = response.json().HASH;",
                  "    pm.collectionVariables.set('hashkey', hashkey);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
