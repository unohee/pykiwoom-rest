{
  "info": {
    "name": "Kiwoom REST API Collection",
    "description": "키움증권 REST API 테스트용 Postman Collection\n\n## 사용법\n1. 환경변수 설정: ACCOUNT_NO, KIWOOM_APPKEY, KIWOOM_APPSECRET\n2. Authorization 탭에서 토큰 발급 후 사용\n3. Rate Limit: 초당 20회 제한\n\n## 주의사항\n- 일부 API는 장시간에만 작동\n- 토큰 유효기간: 24시간\n- 모든 날짜 형식: YYYYMMDD",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://openapi.kiwoom.com",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "account_no",
      "value": "{{ACCOUNT_NO}}",
      "type": "string"
    },
    {
      "key": "app_key",
      "value": "{{KIWOOM_APPKEY}}",
      "type": "string"
    },
    {
      "key": "app_secret",
      "value": "{{KIWOOM_APPSECRET}}",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "description": "인증 관련 API",
      "item": [
        {
          "name": "Get Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"appkey\": \"{{app_key}}\",\n  \"secretkey\": \"{{app_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/oauth2/tokenP",
              "host": ["{{base_url}}"],
              "path": ["oauth2", "tokenP"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', response.access_token);",
                  "    console.log('Access token saved:', response.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Revoke Access Token",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/oauth2/revokeP",
              "host": ["{{base_url}}"],
              "path": ["oauth2", "revokeP"]
            }
          },
          "response": []
        }
      ]
    },
